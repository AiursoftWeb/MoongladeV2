@model Aiursoft.MoongladeV2.Views.Shared.Components.MarketingFooter.MarketingFooterViewModel
@using Microsoft.AspNetCore.Localization

<footer class="py-5 bg-dark text-light">
    <div class="container">
        <div class="row g-4">
            <div class="col-12 col-lg-5">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <img src="@Model.LogoUrl" alt="logo" style="width: 24px; height: 24px;" loading="lazy" />
                    <span class="fw-semibold">@Model.ProjectName</span>
                </div>
                <p class="text-white-50 mb-2">
                    @Localizer["Modern Markdown blogging with AI-powered localization and search."]
                </p>
                <div class="dropdown mt-3">
                    @{
                        var currentCulture = ViewContext.HttpContext.Features
                            .Get<IRequestCultureFeature>()?
                            .RequestCulture.Culture.Name;
                    }
                    <form asp-controller="Culture" asp-action="Set" method="post" class="d-inline" asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)">
                        <select name="culture" onchange="this.form.submit()" class="form-select form-select-sm w-auto">
                            @foreach (var culture in Aiursoft.WebTools.OfficialPlugins.LocalizationPlugin.SupportedCultures)
                            {
                                <option value="@culture.Key"
                                        selected="@(culture.Key == currentCulture ? "selected" : null)">
                                    @culture.Value
                                </option>
                            }
                        </select>
                    </form>
                </div>
            </div>
            <div class="col-6 col-lg-2">
                <h6 class="text-uppercase text-white-50">@Localizer["Explore"]</h6>
                <ul class="list-unstyled mt-3">
                    <li class="mb-2"><a class="text-white-50" asp-controller="Blog" asp-action="Index">@Localizer["Home"]</a></li>
                    <li class="mb-2"><a class="text-white-50" asp-controller="Blog" asp-action="Tags">@Localizer["Tags"]</a></li>
                    <li class="mb-2"><a class="text-white-50" asp-controller="Blog" asp-action="Archive">@Localizer["Archive"]</a></li>
                </ul>
            </div>
            <div class="col-6 col-lg-2">
                <h6 class="text-uppercase text-white-50">@Localizer["Manage"]</h6>
                <ul class="list-unstyled mt-3">
                    <li class="mb-2"><a class="text-white-50" asp-controller="Home" asp-action="Posts">@Localizer["My documents"]</a></li>
                    <li class="mb-2"><a class="text-white-50" asp-controller="GlobalSettings" asp-action="Index">@Localizer["Settings"]</a></li>
                </ul>
            </div>
            <div class="col-12 col-lg-3">
                <h6 class="text-uppercase text-white-50">@Localizer["Brand"]</h6>
                <ul class="list-unstyled mt-3">
                    <li class="mb-2">
                        <a class="text-white-50" href="@Model.BrandHomeUrl" target="_blank">@Model.BrandName</a>
                    </li>
                </ul>
            </div>
        </div>
        <hr class="border-secondary mt-4 mb-3" />
        <p class="text-white-50 mb-0">
            © @DateTime.Now.Year <a href="@Model.BrandHomeUrl" target="_blank">@Model.BrandName</a>
            @if (!string.IsNullOrWhiteSpace(Model.Icp) && System.Globalization.CultureInfo.CurrentCulture.Name == "zh-CN")
            {
                <span> | </span>
                <a href="https://beian.miit.gov.cn/" target="_blank">@Model.Icp</a>
            }
        </p>
    </div>
</footer>
