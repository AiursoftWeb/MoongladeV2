@using Aiursoft.WebTools
@model Aiursoft.MoongladeV2.Models.DashboardViewModels.IndexViewModel

<div class="row mb-2 mb-xl-3">
    <div class="col-auto d-none d-sm-block">
        <h3>@Localizer["Overview"]</h3>
    </div>

    <div class="col-auto ms-auto mt-n1">
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
            <i class="align-middle" data-lucide="file-plus"></i> @Localizer["Create a new document"]
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-6 col-xl-3 mb-4">
        <div class="card h-100 shadow-sm border-0">
            <div class="card-body">
                <div class="row">
                    <div class="col mt-0">
                        <h5 class="card-title">@Localizer["Total Documents"]</h5>
                    </div>
                    <div class="col-auto">
                        <div class="stat text-primary">
                            <i class="align-middle" data-lucide="file-text"></i>
                        </div>
                    </div>
                </div>
                <h1 class="mt-1 mb-3">@Model.TotalDocuments</h1>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3 mb-4">
        <div class="card h-100 shadow-sm border-0">
            <div class="card-body">
                <div class="row">
                    <div class="col mt-0">
                        <h5 class="card-title">@Localizer["Public Posts"]</h5>
                    </div>
                    <div class="col-auto">
                        <div class="stat text-success">
                            <i class="align-middle" data-lucide="globe"></i>
                        </div>
                    </div>
                </div>
                <h1 class="mt-1 mb-3">@Model.PublicPosts</h1>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12 mb-4">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-transparent">
                <h5 class="card-title mb-0"><i class="align-middle me-2 text-primary" data-lucide="clock"></i> @Localizer["Recent Documents"]</h5>
            </div>
            <div class="list-group list-group-flush">
                @if (Model.RecentDocuments != null && Model.RecentDocuments.Any())
                {
                    @foreach (var doc in Model.RecentDocuments)
                    {
                        <a asp-controller="Home" asp-action="Edit" asp-route-id="@doc.Id" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center p-3">
                            <div>
                                <div class="fw-bold">
                                    @if (string.IsNullOrWhiteSpace(doc.Title))
                                    {
                                        <span class="text-muted">(no title)</span>
                                    }
                                    else
                                    {
                                        @doc.Title
                                    }
                                </div>
                                <div class="text-muted small">
                                    @Localizer["Updated:"] <span data-utc-time="@doc.UpdatedAt.ToHtmlDateTime()"></span>
                                    @if (doc.IsPublic)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success ms-2">
                                            <i class="align-middle" data-lucide="globe" style="width:12px;height:12px;"></i> @Localizer["Public"]
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small ms-2">
                                            <i class="align-middle" data-lucide="lock" style="width:12px;height:12px;"></i> @Localizer["Private"]
                                        </span>
                                    }
                                </div>
                            </div>
                            <span class="badge bg-primary rounded-pill">@Localizer["Edit"]</span>
                        </a>
                    }
                }
                else
                {
                    <div class="list-group-item text-muted p-4 text-center">
                        <i class="mb-2 d-block text-muted opacity-50" data-lucide="file-text" style="width: 40px; height: 40px; margin: 0 auto;"></i>
                        @Localizer["No documents yet. Create your first document!"]
                    </div>
                }
            </div>
        </div>
    </div>
</div>
