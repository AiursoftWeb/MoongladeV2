@using Aiursoft.WebTools
@model Aiursoft.MoongladeV2.Models.AdminViewModels.CommentsViewModel

@{
    var rootComments = Model.AllComments
        .Where(c => c.ParentCommentId == null)
        .OrderByDescending(c => c.CreatedAt)
        .ToList();
}

<div class="row mb-2 mb-xl-3">
    <div class="col-auto d-none d-sm-block">
        <h3>@Localizer["Manage Comments"]</h3>
    </div>
    <div class="col-auto ms-auto text-end mt-n1">
        <p class="mb-0 text-muted">@Localizer["View, approve, and delete comments on blog posts."]</p>
    </div>
</div>

<form method="post" asp-controller="Comments" asp-action="DeleteSelected">
    @Html.AntiForgeryToken()
    <div class="card">
        <div class="card-header">
            <div class="d-flex flex-column flex-md-row align-items-md-center gap-2">
                <div>
                    <h5 class="card-title mb-1">@Localizer["All Comments"]</h5>
                    <h6 class="card-subtitle text-muted mb-0">@Model.AllComments.Count @Localizer["total comments"]</h6>
                </div>
                <div class="ms-md-auto">
                    <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('@Localizer["Are you sure you want to delete the selected comments?"]')">
                        <i class="align-middle" data-lucide="trash-2"></i>
                        @Localizer["Delete Selected"]
                    </button>
                </div>
            </div>
        </div>

        @if (!rootComments.Any())
        {
            <div class="card-body">
                <div class="alert alert-info mb-0" role="alert">
                    <div class="alert-message">
                        @Localizer["No comments found."]
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th scope="col" style="width: 40px;">
                                <input type="checkbox" id="select-all" />
                            </th>
                            <th scope="col">@Localizer["Post"]</th>
                            <th scope="col">@Localizer["Author"]</th>
                            <th scope="col">@Localizer["Comment"]</th>
                            <th scope="col">@Localizer["Date"]</th>
                            <th scope="col">@Localizer["Status"]</th>
                            <th scope="col" class="text-end">@Localizer["Actions"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var comment in rootComments)
                        {
                            <tr id="comment-row-@comment.Id">
                                <td>
                                    <input type="checkbox" class="comment-checkbox" name="commentIds" value="@comment.Id" />
                                </td>
                                <td>
                                    <a asp-controller="Blog" asp-action="Post" asp-route-slug="@(comment.Document.Slug ?? comment.DocumentId.ToString())"
                                       target="_blank" class="text-decoration-none">
                                        @(string.IsNullOrWhiteSpace(comment.Document.Title) ? Localizer["(no title)"].Value : comment.Document.Title)
                                    </a>
                                </td>
                                <td>
                                    <span>@comment.User.DisplayName</span>
                                </td>
                                <td>
                                    <span class="text-truncate d-inline-block" style="max-width: 300px;">@comment.Content</span>
                                    @if (comment.Replies.Any())
                                    {
                                        <span class="badge bg-secondary ms-1">@comment.Replies.Count @Localizer["replies"]</span>
                                    }
                                </td>
                                <td>
                                    <label class="text-muted small" data-utc-time="@comment.CreatedAt.ToHtmlDateTime()"></label>
                                </td>
                                <td>
                                    @if (comment.IsApproved)
                                    {
                                        <span class="badge bg-success">@Localizer["Approved"]</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">@Localizer["Pending"]</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <form method="post" asp-controller="Comments" asp-action="ToggleApproval" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="commentId" value="@comment.Id" />
                                        <button type="submit" class="btn btn-sm @(comment.IsApproved ? "btn-outline-warning" : "btn-outline-success")"
                                                title="@(comment.IsApproved ? Localizer["Unapprove"] : Localizer["Approve"])">
                                            @if (comment.IsApproved)
                                            {
                                                <i class="align-middle" data-lucide="x-circle"></i>
                                            }
                                            else
                                            {
                                                <i class="align-middle" data-lucide="check-circle"></i>
                                            }
                                        </button>
                                    </form>
                                    <form method="post" asp-controller="Comments" asp-action="Delete" class="d-inline"
                                          onsubmit="return confirm('@Localizer["Are you sure you want to delete this comment and all its replies?"]')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="commentId" value="@comment.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                                title="@Localizer["Delete"]">
                                            <i class="align-middle" data-lucide="trash-2"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>

                            @if (comment.Replies.Any())
                            {
                                @foreach (var reply in comment.Replies.OrderBy(r => r.CreatedAt))
                                {
                                    <tr id="comment-row-@reply.Id" class="table-light">
                                        <td></td>
                                        <td colspan="2">
                                            <span class="text-muted small">
                                                ↳ @reply.User.DisplayName
                                            </span>
                                        </td>
                                        <td>
                                            <span class="text-muted small text-truncate d-inline-block" style="max-width: 280px;">
                                                @Localizer["Reply:"] @reply.Content
                                            </span>
                                        </td>
                                        <td>
                                            <label class="text-muted small" data-utc-time="@reply.CreatedAt.ToHtmlDateTime()"></label>
                                        </td>
                                        <td></td>
                                        <td class="text-end">
                                            <form method="post" asp-controller="Comments" asp-action="Delete" class="d-inline"
                                                  onsubmit="return confirm('@Localizer["Are you sure you want to delete this reply?"]')">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="commentId" value="@reply.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger"
                                                        title="@Localizer["Delete"]">
                                                    <i class="align-middle" data-lucide="trash-2"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            }
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</form>

@* ReSharper disable once Razor.SectionNotResolved *@
@section scripts {
    <script>
        document.getElementById('select-all')?.addEventListener('change', function () {
            const checkboxes = document.querySelectorAll('.comment-checkbox');
            checkboxes.forEach(cb => cb.checked = this.checked);
        });
    </script>
}
