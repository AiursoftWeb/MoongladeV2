@using Aiursoft.WebTools
@model Aiursoft.MoongladeV2.Models.BlogViewModels.PostViewModel

<vc:marketing-navbar></vc:marketing-navbar>

<main class="container py-4">
    <article class="mx-auto blog-post-article">
        <header class="mb-4">
            <a class="text-decoration-none small" asp-controller="Blog" asp-action="Index">← @Localizer["Back to posts"]</a>
            <h1 class="mt-2">@Model.Title</h1>
            <div class="text-muted">
                @Model.PublishedAt.ToString("yyyy-MM-dd")
                <span class="mx-2">·</span>
                @Model.AuthorName
            </div>
            @if (Model.Tags.Any())
            {
                <div class="d-flex flex-wrap gap-2 mt-3">
                    @foreach (var tag in Model.Tags)
                    {
                        <a class="badge rounded-pill text-bg-light border text-decoration-none" asp-controller="Blog" asp-action="Tag" asp-route-tag="@tag">@tag</a>
                    }
                </div>
            }
        </header>

        @if (!string.IsNullOrWhiteSpace(Model.HeroImageUrl))
        {
            <img src="@Model.HeroImageUrl" alt="@Model.Title" class="img-fluid rounded mb-4 w-100 blog-post-hero" loading="lazy" />
        }

        <section class="markdown-content blog-markdown-body">
            @Html.Raw(Model.ContentHtml)
        </section>

        <!-- Comments Section -->
        <section id="comments" class="mt-5">
            <h5 class="mb-3">
                <i class="align-middle me-1" data-lucide="message-circle"></i>
                @Localizer["Comments"] (@Model.CommentCount)
            </h5>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="card mb-4">
                    <div class="card-body">
                        <form asp-controller="Comments" asp-action="Post" method="post">
                            <input type="hidden" name="documentId" value="@Model.DocumentId" />
                            @Html.AntiForgeryToken()
                            <div class="mb-2">
                                <textarea name="content" class="form-control" rows="3"
                                          placeholder="@Localizer["Write your comment…"]" maxlength="1000" required></textarea>
                            </div>
                            <button type="submit" class="btn btn-primary btn-sm">@Localizer["Post Comment"]</button>
                        </form>
                    </div>
                </div>
            }

            @foreach (var comment in Model.Comments)
            {
                <div class="card mb-3" id="comment-@comment.Id">
                    <div class="card-body">
                        <div class="d-flex gap-3">
                            <div class="flex-shrink-0">
                                <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center"
                                     style="width: 40px; height: 40px; font-size: 16px;">
                                    @(comment.User.DisplayName.Length > 0 ? comment.User.DisplayName[0].ToString().ToUpper() : "?")
                                </div>
                            </div>
                            <div class="flex-grow-1">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <div>
                                        <strong class="me-2">@comment.User.DisplayName</strong>
                                        <small class="text-muted"><label data-utc-time="@comment.CreatedAt.ToHtmlDateTime()"></label></small>
                                    </div>
                                    @if (User.Identity?.IsAuthenticated == true &&
                                         User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value == comment.UserId)
                                    {
                                        <form asp-controller="Comments" asp-action="Delete" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="commentId" value="@comment.Id" />
                                            <button type="submit" class="btn btn-link btn-sm text-danger p-0"
                                                    onclick="return confirm('@Localizer["Are you sure you want to delete this comment?"]')">@Localizer["Delete"]</button>
                                        </form>
                                    }
                                </div>
                                <p class="mb-2">@comment.Content</p>

                                <!-- Replies -->
                                @if (comment.Replies.Any())
                                {
                                    <div class="border-start ps-3 mt-2">
                                        @foreach (var reply in comment.Replies.OrderBy(r => r.CreatedAt))
                                        {
                                            <div class="d-flex gap-2 mb-2 pt-2" id="comment-@reply.Id">
                                                <div class="flex-shrink-0">
                                                    <div class="rounded-circle bg-light border d-flex align-items-center justify-content-center"
                                                         style="width: 32px; height: 32px; font-size: 12px;">
                                                        @(reply.User.DisplayName.Length > 0 ? reply.User.DisplayName[0].ToString().ToUpper() : "?")
                                                    </div>
                                                </div>
                                                <div class="flex-grow-1">
                                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                                        <div>
                                                            <strong class="me-2">@reply.User.DisplayName</strong>
                                                            <small class="text-muted"><label data-utc-time="@reply.CreatedAt.ToHtmlDateTime()"></label></small>
                                                        </div>
                                                        @if (User.Identity?.IsAuthenticated == true &&
                                                             User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value == reply.UserId)
                                                        {
                                                            <form asp-controller="Comments" asp-action="Delete" method="post" class="d-inline">
                                                                @Html.AntiForgeryToken()
                                                                <input type="hidden" name="commentId" value="@reply.Id" />
                                                                <button type="submit" class="btn btn-link btn-sm text-danger p-0"
                                                                        onclick="return confirm('@Localizer["Are you sure you want to delete this reply?"]')">@Localizer["Delete"]</button>
                                                            </form>
                                                        }
                                                    </div>
                                                    <p class="mb-0">@reply.Content</p>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }

                                <!-- Reply Form -->
                                @if (User.Identity?.IsAuthenticated == true)
                                {
                                    <div class="mt-2">
                                        <a class="btn btn-link btn-sm p-0 text-secondary toggle-reply"
                                           data-target="reply-form-@comment.Id">@Localizer["Reply"]</a>
                                        <div id="reply-form-@comment.Id" class="d-none mt-2">
                                            <form asp-controller="Comments" asp-action="Post" method="post">
                                                <input type="hidden" name="documentId" value="@Model.DocumentId" />
                                                <input type="hidden" name="parentCommentId" value="@comment.Id" />
                                                @Html.AntiForgeryToken()
                                                <div class="mb-1">
                                                    <textarea name="content" class="form-control form-control-sm" rows="2"
                                                              placeholder="@string.Format(Localizer["Reply to {0}..."].Value, comment.User.DisplayName)"
                                                              maxlength="1000" required></textarea>
                                                </div>
                                                <button type="submit" class="btn btn-secondary btn-sm">@Localizer["Send Reply"]</button>
                                            </form>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }

            @if (Model.CommentCount == 0)
            {
                <p class="text-muted text-center py-3">@Localizer["No comments yet. Be the first to leave one!"]</p>
            }

            @if (User.Identity?.IsAuthenticated != true)
            {
                <div class="text-center py-3">
                    <a href="/Account/Login?returnUrl=@Uri.EscapeDataString(Context.Request.Path + Context.Request.QueryString)"
                       class="btn btn-outline-primary">
                        <i class="align-middle me-1" data-lucide="log-in"></i>
                        @Localizer["Login to comment"]
                    </a>
                </div>
            }
        </section>
    </article>
</main>

<vc:marketing-footer></vc:marketing-footer>

@* ReSharper disable once Razor.SectionNotResolved *@
@section scripts {
    <script>
        document.querySelectorAll(".toggle-reply").forEach(function (el) {
            el.addEventListener("click", function (e) {
                e.preventDefault();
                var target = document.getElementById(this.dataset.target);
                if (target) {
                    target.classList.toggle("d-none");
                }
            });
        });
    </script>
}

@* ReSharper disable once Razor.SectionNotResolved *@
@section styles {
    <link rel="stylesheet" href="~/styles/markdown-reader.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/styles/blog.css" asp-append-version="true" />
}
