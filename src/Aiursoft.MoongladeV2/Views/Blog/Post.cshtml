@using Aiursoft.WebTools
@using Aiursoft.MoongladeV2.Controllers
@using System.Globalization
@model Aiursoft.MoongladeV2.Models.BlogViewModels.PostViewModel

@{
    var isDarkMode = Context.Request.Cookies[ThemeController.ThemeCookieKey] == true.ToString();
}

<vc:marketing-navbar></vc:marketing-navbar>

<main class="moonglade-blog-shell body-post-slug @(isDarkMode ? "darkmode" : null)">
    <div class="container py-4 py-lg-5">
        <article class="article-post-slug box border position-relative mb-4" data-postid="@Model.DocumentId" lang="@CultureInfo.CurrentCulture.TwoLetterISOLanguageName">
            <header class="post-header text-center">
                <a class="post-back-link" asp-controller="Blog" asp-action="Index">@Localizer["Back to posts"]</a>
                <h1 class="post-title font-sairas">@Model.Title</h1>

                <div class="post-publish-info text-muted mb-2">
                    <span class="me-2">
                        <span class="post-meta-label">@Localizer["By"]</span>
                        @Model.AuthorName
                    </span>
                    <span class="me-2">
                        <span class="post-meta-label">@Localizer["Published"]</span>
                        <time datetime="@Model.PublishedAt.ToString("O", CultureInfo.InvariantCulture)">
                            @Model.PublishedAt.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)
                        </time>
                    </span>
                </div>

                @if (Model.Tags.Any())
                {
                    <div class="post-summary-tags mt-3">
                        @foreach (var tag in Model.Tags)
                        {
                            <a class="d-inline-block me-1 mb-1 btn btn-sm btn-accent" asp-controller="Blog" asp-action="Tag" asp-route-tag="@tag">@tag</a>
                        }
                    </div>
                }

                <hr class="d-none d-md-block" />
            </header>

            @if (!string.IsNullOrWhiteSpace(Model.HeroImageUrl))
            {
                <div class="post-hero-image-container text-center mb-3">
                    <img src="@Model.HeroImageUrl" alt="@Model.Title" class="post-hero-image img-fluid rounded-3 shadow-sm" loading="lazy" />
                </div>
            }

            <section class="post-content markdown-content clearfix">
                @Html.Raw(Model.ContentHtml)
            </section>
        </article>

        <section id="comments" class="box comment-form-containter mb-4">
            <h5 class="mb-3">@Localizer["Comments"] (@Model.CommentCount)</h5>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <form asp-controller="Comments" asp-action="Post" method="post" class="mb-4">
                    <input type="hidden" name="documentId" value="@Model.DocumentId" />
                    @Html.AntiForgeryToken()
                    <div class="mb-2">
                        <textarea name="content" class="form-control" rows="3" placeholder="@Localizer["Write your comment..."]" maxlength="1000" required></textarea>
                    </div>
                    <button type="submit" class="btn btn-accent btn-sm">@Localizer["Post Comment"]</button>
                </form>
            }

            @if (Model.CommentCount == 0)
            {
                <p class="text-muted text-center py-3">@Localizer["No comments yet. Be the first to leave one!"]</p>
            }

            <div class="comment-list">
                @foreach (var comment in Model.Comments)
                {
                    <div class="comment-item mb-3" id="comment-@comment.Id">
                        <div class="d-flex gap-3">
                            <div class="flex-shrink-0">
                                <div class="comment-avatar">
                                    @(comment.User.DisplayName.Length > 0 ? comment.User.DisplayName[0].ToString().ToUpper(CultureInfo.CurrentCulture) : "?")
                                </div>
                            </div>
                            <div class="flex-grow-1">
                                <div class="comment-bubble">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <div>
                                            <strong class="me-2">@comment.User.DisplayName</strong>
                                            <small class="text-muted"><label data-utc-time="@comment.CreatedAt.ToHtmlDateTime()"></label></small>
                                        </div>
                                        @if (User.Identity?.IsAuthenticated == true &&
                                             User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value == comment.UserId)
                                        {
                                            <form asp-controller="Comments" asp-action="Delete" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="commentId" value="@comment.Id" />
                                                <button type="submit" class="btn btn-link btn-sm text-danger p-0" onclick="return confirm('@Localizer["Are you sure you want to delete this comment?"]')">@Localizer["Delete"]</button>
                                            </form>
                                        }
                                    </div>
                                    <p class="mb-2">@comment.Content</p>

                                    @if (comment.Replies.Any())
                                    {
                                        <div class="comment-replies">
                                            @foreach (var reply in comment.Replies.OrderBy(r => r.CreatedAt))
                                            {
                                                <div class="d-flex gap-2 mb-2 pt-2" id="comment-@reply.Id">
                                                    <div class="flex-shrink-0">
                                                        <div class="comment-avatar comment-avatar-sm">
                                                            @(reply.User.DisplayName.Length > 0 ? reply.User.DisplayName[0].ToString().ToUpper(CultureInfo.CurrentCulture) : "?")
                                                        </div>
                                                    </div>
                                                    <div class="flex-grow-1">
                                                        <div class="d-flex justify-content-between align-items-center mb-1">
                                                            <div>
                                                                <strong class="me-2">@reply.User.DisplayName</strong>
                                                                <small class="text-muted"><label data-utc-time="@reply.CreatedAt.ToHtmlDateTime()"></label></small>
                                                            </div>
                                                            @if (User.Identity?.IsAuthenticated == true &&
                                                                 User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value == reply.UserId)
                                                            {
                                                                <form asp-controller="Comments" asp-action="Delete" method="post" class="d-inline">
                                                                    @Html.AntiForgeryToken()
                                                                    <input type="hidden" name="commentId" value="@reply.Id" />
                                                                    <button type="submit" class="btn btn-link btn-sm text-danger p-0" onclick="return confirm('@Localizer["Are you sure you want to delete this reply?"]')">@Localizer["Delete"]</button>
                                                                </form>
                                                            }
                                                        </div>
                                                        <p class="mb-0">@reply.Content</p>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }

                                    @if (User.Identity?.IsAuthenticated == true)
                                    {
                                        <div class="mt-2">
                                            <a class="btn btn-link btn-sm p-0 text-secondary toggle-reply" data-target="reply-form-@comment.Id">@Localizer["Reply"]</a>
                                            <div id="reply-form-@comment.Id" class="d-none mt-2">
                                                <form asp-controller="Comments" asp-action="Post" method="post">
                                                    <input type="hidden" name="documentId" value="@Model.DocumentId" />
                                                    <input type="hidden" name="parentCommentId" value="@comment.Id" />
                                                    @Html.AntiForgeryToken()
                                                    <div class="mb-1">
                                                        <textarea name="content" class="form-control form-control-sm" rows="2" placeholder="@string.Format(Localizer["Reply to {0}..."].Value, comment.User.DisplayName)" maxlength="1000" required></textarea>
                                                    </div>
                                                    <button type="submit" class="btn btn-outline-accent btn-sm">@Localizer["Send Reply"]</button>
                                                </form>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (User.Identity?.IsAuthenticated != true)
            {
                <div class="text-center py-3">
                    <a href="/Account/Login?returnUrl=@Uri.EscapeDataString(Context.Request.Path + Context.Request.QueryString)" class="btn btn-outline-accent">
                        @Localizer["Login to comment"]
                    </a>
                </div>
            }
        </section>
    </div>
</main>

<vc:marketing-footer></vc:marketing-footer>

@* ReSharper disable once Razor.SectionNotResolved *@
@section scripts {
    <script src="~/node_modules/@@highlightjs/cdn-assets/highlight.min.js" asp-append-version="true"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            hljs.highlightAll();
        });
    </script>
    <script>
        document.querySelectorAll(".toggle-reply").forEach(function (el) {
            el.addEventListener("click", function (e) {
                e.preventDefault();
                var target = document.getElementById(this.dataset.target);
                if (target) {
                    target.classList.toggle("d-none");
                }
            });
        });
    </script>
}

@* ReSharper disable once Razor.SectionNotResolved *@
@section styles {
    <link rel="stylesheet" href="~/node_modules/@@fontsource/cascadia-code/index.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/styles/markdown-reader.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/styles/blog.css" asp-append-version="true" />
    @if (isDarkMode)
    {
        <link rel="stylesheet" href="~/node_modules/@@highlightjs/cdn-assets/styles/github-dark.min.css" asp-append-version="true" />
    }
    else
    {
        <link rel="stylesheet" href="~/node_modules/@@highlightjs/cdn-assets/styles/github.min.css" asp-append-version="true" />
    }
}
