@using System.Globalization
@model Aiursoft.MoongladeV2.Models.BlogViewModels.IndexViewModel

@{
    string BuildSortUrl(string sort)
    {
        if (!string.IsNullOrWhiteSpace(Model.CurrentTag))
        {
            return Url.Action("Tag", "Blog", new { tag = Model.CurrentTag, sort, page = 1 }) ?? "/";
        }

        if (!string.IsNullOrWhiteSpace(Model.SearchQuery))
        {
            return Url.Action("Search", "Blog", new { q = Model.SearchQuery, sort, page = 1 }) ?? "/";
        }

        return Url.Action("Index", "Blog", new { sort, page = 1 }) ?? "/";
    }

    string BuildPageUrl(int page)
    {
        if (!string.IsNullOrWhiteSpace(Model.CurrentTag))
        {
            return Url.Action("Tag", "Blog", new { tag = Model.CurrentTag, sort = Model.SortBy, page }) ?? "/";
        }

        if (!string.IsNullOrWhiteSpace(Model.SearchQuery))
        {
            return Url.Action("Search", "Blog", new { q = Model.SearchQuery, sort = Model.SortBy, page }) ?? "/";
        }

        return Url.Action("Index", "Blog", new { sort = Model.SortBy, page }) ?? "/";
    }

    var pageHeading = Localizer["All Posts"].Value;
    if (!string.IsNullOrWhiteSpace(Model.CurrentTag))
    {
        pageHeading = $"{Localizer["Tag"].Value}: {Model.CurrentTag}";
    }
    else if (!string.IsNullOrWhiteSpace(Model.SearchQuery))
    {
        pageHeading = $"{Localizer["Search"].Value}: {Model.SearchQuery}";
    }
}

<vc:marketing-navbar></vc:marketing-navbar>

<main class="moonglade-blog-shell">
    <section class="profile-mobile d-block d-sm-none">
        <div class="card-bkimg-container">
            <img class="card-bkimg" src="~/images/default-avatar.jpg" alt="" />
        </div>
        <div class="blogger-intro-content">
            <div class="row align-items-center">
                <div class="col-3">
                    <img src="~/images/default-avatar.jpg" alt="Moonglade" class="rounded-circle blogger-head-pic" />
                </div>
                <div class="col-9">
                    <h4 class="text-center">@Localizer["Modern Markdown blogging with AI-powered localization and search."]</h4>
                </div>
            </div>
        </div>
    </section>

    <div class="container py-4 py-lg-5">
        <div class="row g-4">
            <section class="col-lg-9">
                <div class="d-flex align-items-center mb-3 blog-index-heading">
                    <h3 class="mb-0">@pageHeading</h3>
                    <span class="flex-spacer"></span>

                    @if (!Model.UsedAiSearch)
                    {
                        <div class="btn-group btn-group-sm" role="group" aria-label="@Localizer["Sort posts"]">
                            <a href="@BuildSortUrl("recent")" class="btn @(Model.SortBy == "Recent" ? "btn-accent" : "btn-outline-accent")">@Localizer["Recent"]</a>
                            <a href="@BuildSortUrl("featured")" class="btn @(Model.SortBy == "Featured" ? "btn-accent" : "btn-outline-accent")">@Localizer["Featured"]</a>
                        </div>
                    }
                </div>
                <hr class="blog-heading-rule" />

                @if (Model.UsedAiSearch || Model.RateLimited)
                {
                    <div class="blog-search-state mb-4">
                        @if (Model.UsedAiSearch)
                        {
                            <span class="badge text-bg-success">@Localizer["Search based on AI (Vector Database)"]</span>
                        }
                        @if (Model.RateLimited)
                        {
                            <span class="badge text-bg-warning">@Localizer["Too many searches. AI search temporarily limited; showing keyword results."]</span>
                        }
                    </div>
                }

                @if (!Model.Posts.Any())
                {
                    <div class="alert alert-info">@Localizer["No posts found."]</div>
                }
                else
                {
                    @foreach (var post in Model.Posts)
                    {
                        <article class="article-post-summary d-flex" lang="@CultureInfo.CurrentCulture.TwoLetterISOLanguageName">
                            <div class="post-date-box d-none d-md-block font-sairas me-4">
                                <div class="post-date-day">@post.PublishedAt.Day.ToString("00", CultureInfo.InvariantCulture)</div>
                                <div class="post-date-month text-white">@post.PublishedAt.ToString("MMM", CultureInfo.CurrentCulture).ToUpper(CultureInfo.CurrentCulture)</div>
                            </div>

                            <div class="post-summary-box">
                                <time datetime="@post.PublishedAt.ToString("O", CultureInfo.InvariantCulture)" class="d-none">
                                    @post.PublishedAt.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)
                                </time>

                                <h4 class="post-summary-title mb-3">
                                    <a href="@post.Url">@post.Title</a>
                                    @if (post.IsFeatured)
                                    {
                                        <span class="post-featured-star" title="@Localizer["Featured"]">★</span>
                                    }
                                </h4>

                                @if (!string.IsNullOrWhiteSpace(post.HeroImageUrl))
                                {
                                    <a href="@post.Url" class="post-summary-hero-link">
                                        <img src="@post.HeroImageUrl" alt="@post.Title" class="post-summary-hero" loading="lazy" />
                                    </a>
                                }

                                <p class="post-summary-text">@post.Excerpt</p>

                                @if (post.Tags.Any())
                                {
                                    <div class="post-summary-tags pt-2">
                                        @foreach (var tag in post.Tags)
                                        {
                                            <a asp-controller="Blog" asp-action="Tag" asp-route-tag="@tag" class="d-inline-block me-1 mb-1 btn btn-sm btn-accent">@tag</a>
                                        }
                                    </div>
                                }
                            </div>
                        </article>
                        <div class="mb-4 d-none d-md-block"></div>
                        <hr class="d-none d-md-block blog-post-separator" />
                    }
                }

                @if (Model.TotalPages > 1)
                {
                    <nav aria-label="@Localizer["Blog pagination"]">
                        <ul class="pagination justify-content-end">
                            <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : string.Empty)">
                                <a class="page-link" href="@BuildPageUrl(Model.CurrentPage - 1)">@Localizer["Previous"]</a>
                            </li>
                            @for (var i = 1; i <= Model.TotalPages; i++)
                            {
                                <li class="page-item @(Model.CurrentPage == i ? "active" : string.Empty)">
                                    <a class="page-link" href="@BuildPageUrl(i)">@i</a>
                                </li>
                            }
                            <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : string.Empty)">
                                <a class="page-link" href="@BuildPageUrl(Model.CurrentPage + 1)">@Localizer["Next"]</a>
                            </li>
                        </ul>
                    </nav>
                }
            </section>

            <aside class="col-lg-3 blog-sidebar">
                <section class="blog-info-desktop-lg text-light d-none d-sm-block">
                    <div class="card-with-avatar">
                        <img class="card-bkimg" src="~/images/default-avatar.jpg" alt="" />
                    </div>
                    <div class="blog-info-photo-text text-center">
                        <img src="~/images/default-avatar.jpg" alt="Moonglade" class="rounded-circle blogger-head-pic" />
                        <div>
                            <h3 class="mt-3 text-white font-sairas">Moonglade</h3>
                            <p class="me-3 ms-3">@Localizer["Modern Markdown blogging with AI-powered localization and search."]</p>
                        </div>
                    </div>
                </section>

                <section class="box mt-4">
                    <h5>@Localizer["Search"]</h5>
                    <form asp-controller="Blog" asp-action="Search" method="get">
                        <div class="input-group input-group-sm">
                            <input type="text" name="q" class="form-control" value="@Model.SearchQuery" placeholder="@Localizer["Keywords"]" />
                            <button class="btn btn-accent" type="submit">@Localizer["Go"]</button>
                        </div>
                    </form>
                </section>

                <section class="box mt-4">
                    <h5>@Localizer["Tags"]</h5>
                    <div class="post-summary-tags">
                        @foreach (var item in Model.TopTags.Take(20))
                        {
                            <a class="d-inline-block me-1 mb-1 btn btn-sm btn-outline-accent" asp-controller="Blog" asp-action="Tag" asp-route-tag="@item.Tag">
                                @item.Tag <span class="tag-count">@item.Count</span>
                            </a>
                        }
                    </div>
                    <hr />
                    <a asp-controller="Blog" asp-action="Tags">@Localizer["All tags"]</a>
                </section>

                <section class="text-center mt-4">
                    <a asp-controller="Blog" asp-action="Archive" class="btn btn-sm btn-round btn-outline-secondary">@Localizer["Archive"]</a>
                </section>
            </aside>
        </div>
    </div>
</main>

<vc:marketing-footer></vc:marketing-footer>

@* ReSharper disable once Razor.SectionNotResolved *@
@section styles {
    <link rel="stylesheet" href="~/styles/blog.css" asp-append-version="true" />
}
